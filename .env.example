# =====================================================================
# LiteLLM Gateway — variáveis de ambiente para docker compose
# ---------------------------------------------------------------------
# Copie este arquivo para .env e preencha com os valores reais:
#     cp .env.example .env
#
# O arquivo .env NÃO deve ser commitado no Git (já está no .gitignore).
# =====================================================================

# ---- API keys reais (NUNCA distribuir para devs) --------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Credencial administrativa do gateway ---------------------------
# Gerar com:
#   python -c "import secrets; print('sk-' + secrets.token_urlsafe(48))"
# ou dentro do WSL:
#   openssl rand -base64 48 | tr '+/' '-_' | tr -d '=' | sed 's/^/sk-/'
LITELLM_MASTER_KEY=sk-trocar-por-master-key-segura-de-48-bytes

# ---- PostgreSQL (rede interna do compose, não exposto à LAN) --------
POSTGRES_USER=litellm_user
POSTGRES_PASSWORD=trocar-por-senha-forte
POSTGRES_DB=litellm
